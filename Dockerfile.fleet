# Dockerfile.fleet
# =================
# Minimal runtime image for the SEISMOGRAPH first-party probe fleet.
#
# This is intentionally separate from the main Dockerfile, which builds
# the gateway/engine stack and explicitly excludes probe/ (AD-CONTAINER-003:
# the probe is a client library, not a server component).
#
# The fleet container only needs:
#   - probe/ (the ProbeSDK and supporting modules)
#   - scripts/first_party_fleet.py (the runner)
#   - httpx, cryptography (probe runtime deps)
#
# Non-root execution: runs as uid 1001 (seismograph) for security.
# Key directory /var/seismograph is created and chowned at build time;
# the fleet_key volume is mounted there at runtime so the Ed25519
# keypair survives container restarts.

FROM python:3.11-slim

# Install pinned runtime deps -- no dev tools, no build cache
# Versions pinned in requirements-fleet.txt (KNOWN-LIMIT-FLEET-002)
COPY requirements-fleet.txt .
RUN pip install --no-cache-dir -r requirements-fleet.txt

# Non-root user (uid 1001)
RUN useradd --uid 1001 --create-home --shell /bin/bash seismograph

# Copy probe SDK and fleet runner
WORKDIR /app
COPY probe/ probe/
COPY scripts/first_party_fleet.py scripts/first_party_fleet.py

# Key persistence directory -- mounted as a named volume at runtime
RUN mkdir -p /var/seismograph && chown 1001:1001 /var/seismograph

USER seismograph

# -u: unbuffered stdout/stderr so logs appear immediately in docker logs
CMD ["python3", "-u", "scripts/first_party_fleet.py"]
